---
import "../app.css";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
};

const {
  title = "Unlucky Boys",
  description = "Unlucky Boys esports NHL team hub",
  bodyClass = "",
} = Astro.props;

const nav = [
  { href: "/news", label: "News" },
  { href: "/games", label: "Season History" },
  { href: "/roster", label: "Roster" },
  { href: "/history", label: "About us" },
  { href: "/hall-of-fame", label: "Hall of Fame" },
  { href: "/achievements-records", label: "Achievements & Records" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  er
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/brand/logo.png" />
    <title>{title}</title>
  </head>
  <body class:list={[bodyClass]}>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="brand">
          <img
            class="brand-mark"
            src="/brand/logo.png"
            alt="Unlucky Boys logo"
          />
        </a>
        <button
          class="menu-toggle"
          type="button"
          aria-label="Open navigation menu"
          aria-controls="main-navigation"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav id="main-navigation" class="main-nav" aria-label="Main navigation">
          {
            nav.map((item) => (
              <a
                class:list={[{ active: currentPath === item.href }]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <strong>Unlucky Boys</strong>
      <a
        href="https://twitter.com/UnluckyBoysNHL"
        target="_blank"
        rel="noreferrer">Contact UB on X</a
      >
      <a class="admin-login-link" href="/admin">Login</a>
    </footer>
    <script is:inline>
      const header = document.querySelector(".site-header");
      const toggle = document.querySelector(".menu-toggle");
      const navigation = document.querySelector("#main-navigation");

      const setMenuOpen = (open) => {
        header?.classList.toggle("menu-open", open);
        toggle?.setAttribute("aria-expanded", String(open));
        toggle?.setAttribute(
          "aria-label",
          open ? "Close navigation menu" : "Open navigation menu",
        );
      };

      toggle?.addEventListener("click", () => {
        setMenuOpen(!header?.classList.contains("menu-open"));
      });

      navigation?.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement) setMenuOpen(false);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMenuOpen(false);
      });

      window
        .matchMedia("(min-width: 821px)")
        .addEventListener("change", (event) => {
          if (event.matches) setMenuOpen(false);
        });
    </script>
  </body>
</html>
