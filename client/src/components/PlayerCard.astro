---
import type { Player } from "@lib/types";
import { playerInitials } from "@lib/format";

type Props = {
  player: Player;
};

const { player } = Astro.props;
const isCaptain = Boolean(player.captain);
const isAlternateCaptain = Boolean(player.alternateCaptain);
---

<a class="player-card" href={`/players/${player.slug}`}>
  {player.imageUrl ? (
    <img src={player.imageUrl} alt={player.name} />
  ) : (
    <div class="player-placeholder">{playerInitials(player.name)}</div>
  )}
  <span class="card-meta">#{player.number} · {player.position} · {player.nationality || "FIN"}</span>
  <strong>{player.name}</strong>
  {player.nickname && <em>{player.nickname}</em>}
  {(isCaptain || isAlternateCaptain) && (
    <small class="captain-badge">{isCaptain ? "C" : "A"}</small>
  )}
</a>
