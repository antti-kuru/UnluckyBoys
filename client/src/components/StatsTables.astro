---
import type { GoalieStat, SkaterStat } from "@lib/types";

type Props = {
  skaterStats: SkaterStat[];
  skaterPlayoffStats?: SkaterStat[];
  goalieStats: GoalieStat[];
  goaliePlayoffStats?: GoalieStat[];
};

const {
  skaterStats,
  skaterPlayoffStats = [],
  goalieStats,
  goaliePlayoffStats = [],
} = Astro.props;

function skaterTotal(stats: SkaterStat[]) {
  return stats.reduce(
    (total, stat) => ({
      gamesPlayed: total.gamesPlayed + stat.gamesPlayed,
      goals: total.goals + stat.goals,
      assists: total.assists + stat.assists,
      points: total.points + stat.points,
      penaltyMinutes: total.penaltyMinutes + stat.penaltyMinutes,
      plusMinus: total.plusMinus + stat.plusMinus,
    }),
    { gamesPlayed: 0, goals: 0, assists: 0, points: 0, penaltyMinutes: 0, plusMinus: 0 }
  );
}

function goalieTotal(stats: GoalieStat[]) {
  return stats.reduce(
    (total, stat) => ({
      gamesPlayed: total.gamesPlayed + stat.gamesPlayed,
      wins: total.wins + stat.wins,
      losses: total.losses + stat.losses,
      overtimeLosses: total.overtimeLosses + stat.overtimeLosses,
      saves: total.saves + stat.saves,
      goalsAgainst: total.goalsAgainst + stat.goalsAgainst,
      shutouts: total.shutouts + stat.shutouts,
      penaltyMinutes: total.penaltyMinutes + stat.penaltyMinutes,
    }),
    { gamesPlayed: 0, wins: 0, losses: 0, overtimeLosses: 0, saves: 0, goalsAgainst: 0, shutouts: 0, penaltyMinutes: 0 }
  );
}

function goalieSavePercentage(total: ReturnType<typeof goalieTotal>) {
  const shotsAgainst = total.saves + total.goalsAgainst;
  return shotsAgainst > 0 ? ((total.saves / shotsAgainst) * 100).toFixed(2) : "-";
}

function goalieGoalsAgainstAverage(total: ReturnType<typeof goalieTotal>) {
  return total.gamesPlayed > 0 ? (total.goalsAgainst / total.gamesPlayed).toFixed(2) : "-";
}

const regularSkaterTotal = skaterTotal(skaterStats);
const playoffSkaterTotal = skaterTotal(skaterPlayoffStats);
const regularGoalieTotal = goalieTotal(goalieStats);
const playoffGoalieTotal = goalieTotal(goaliePlayoffStats);
---

<section class="stats-section">
  <h2>Regular Season Stats</h2>
  <div class="table-wrap player-stats-wrap">
    <table class="player-stats-table player-skater-stats">
      <thead>
        <tr>
          <th>League</th>
          <th>Team</th>
          <th>GP</th>
          <th>G</th>
          <th>A</th>
          <th>TP</th>
          <th>PIM</th>
          <th>+/-</th>
        </tr>
      </thead>
      <tbody>
        {skaterStats.map((stat) => (
          <tr>
            <td>{stat.league}</td>
            <td>{stat.teamName}</td>
            <td>{stat.gamesPlayed}</td>
            <td>{stat.goals}</td>
            <td>{stat.assists}</td>
            <td>{stat.points}</td>
            <td>{stat.penaltyMinutes}</td>
            <td>{stat.plusMinus}</td>
          </tr>
        ))}
        {skaterStats.length > 0 && (
          <tr class="total-row">
            <td>Total</td>
            <td>All teams</td>
            <td>{regularSkaterTotal.gamesPlayed}</td>
            <td>{regularSkaterTotal.goals}</td>
            <td>{regularSkaterTotal.assists}</td>
            <td>{regularSkaterTotal.points}</td>
            <td>{regularSkaterTotal.penaltyMinutes}</td>
            <td>{regularSkaterTotal.plusMinus}</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>

  {skaterPlayoffStats.length > 0 && (
    <>
      <h2>Playoff Stats</h2>
      <div class="table-wrap player-stats-wrap">
        <table class="player-stats-table player-skater-stats">
          <thead>
            <tr>
              <th>League</th>
              <th>Team</th>
              <th>GP</th>
              <th>G</th>
              <th>A</th>
              <th>TP</th>
              <th>PIM</th>
              <th>+/-</th>
            </tr>
          </thead>
          <tbody>
            {skaterPlayoffStats.map((stat) => (
              <tr>
                <td>{stat.league}</td>
                <td>{stat.teamName}</td>
                <td>{stat.gamesPlayed}</td>
                <td>{stat.goals}</td>
                <td>{stat.assists}</td>
                <td>{stat.points}</td>
                <td>{stat.penaltyMinutes}</td>
                <td>{stat.plusMinus}</td>
              </tr>
            ))}
            <tr class="total-row">
              <td>Total</td>
              <td>All teams</td>
              <td>{playoffSkaterTotal.gamesPlayed}</td>
              <td>{playoffSkaterTotal.goals}</td>
              <td>{playoffSkaterTotal.assists}</td>
              <td>{playoffSkaterTotal.points}</td>
              <td>{playoffSkaterTotal.penaltyMinutes}</td>
              <td>{playoffSkaterTotal.plusMinus}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </>
  )}

  {goalieStats.length > 0 && (
    <>
      <h2>Goalie Regular Season Stats</h2>
      <div class="table-wrap player-stats-wrap">
        <table class="player-stats-table player-goalie-stats">
          <thead>
            <tr>
              <th>League</th>
              <th>Team</th>
              <th>GP</th>
              <th>W</th>
              <th>L</th>
              <th>OTL</th>
              <th>SV%</th>
              <th>GAA</th>
              <th>SO</th>
              <th>PIM</th>
            </tr>
          </thead>
          <tbody>
            {goalieStats.map((stat) => (
              <tr>
                <td>{stat.league}</td>
                <td>{stat.teamName}</td>
                <td>{stat.gamesPlayed}</td>
                <td>{stat.wins}</td>
                <td>{stat.losses}</td>
                <td>{stat.overtimeLosses}</td>
                <td>{stat.savePercentage ?? "-"}</td>
                <td>{stat.goalsAgainstAverage ?? "-"}</td>
                <td>{stat.shutouts}</td>
                <td>{stat.penaltyMinutes}</td>
              </tr>
            ))}
            <tr class="total-row">
              <td>Total</td>
              <td>All teams</td>
              <td>{regularGoalieTotal.gamesPlayed}</td>
              <td>{regularGoalieTotal.wins}</td>
              <td>{regularGoalieTotal.losses}</td>
              <td>{regularGoalieTotal.overtimeLosses}</td>
              <td>{goalieSavePercentage(regularGoalieTotal)}</td>
              <td>{goalieGoalsAgainstAverage(regularGoalieTotal)}</td>
              <td>{regularGoalieTotal.shutouts}</td>
              <td>{regularGoalieTotal.penaltyMinutes}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </>
  )}

  {goaliePlayoffStats.length > 0 && (
    <>
      <h2>Goalie Playoff Stats</h2>
      <div class="table-wrap player-stats-wrap">
        <table class="player-stats-table player-goalie-stats">
          <thead>
            <tr>
              <th>League</th>
              <th>Team</th>
              <th>GP</th>
              <th>W</th>
              <th>L</th>
              <th>OTL</th>
              <th>SV%</th>
              <th>GAA</th>
              <th>SO</th>
              <th>PIM</th>
            </tr>
          </thead>
          <tbody>
            {goaliePlayoffStats.map((stat) => (
              <tr>
                <td>{stat.league}</td>
                <td>{stat.teamName}</td>
                <td>{stat.gamesPlayed}</td>
                <td>{stat.wins}</td>
                <td>{stat.losses}</td>
                <td>{stat.overtimeLosses}</td>
                <td>{stat.savePercentage ?? "-"}</td>
                <td>{stat.goalsAgainstAverage ?? "-"}</td>
                <td>{stat.shutouts}</td>
                <td>{stat.penaltyMinutes}</td>
              </tr>
            ))}
            <tr class="total-row">
              <td>Total</td>
              <td>All teams</td>
              <td>{playoffGoalieTotal.gamesPlayed}</td>
              <td>{playoffGoalieTotal.wins}</td>
              <td>{playoffGoalieTotal.losses}</td>
              <td>{playoffGoalieTotal.overtimeLosses}</td>
              <td>{goalieSavePercentage(playoffGoalieTotal)}</td>
              <td>{goalieGoalsAgainstAverage(playoffGoalieTotal)}</td>
              <td>{playoffGoalieTotal.shutouts}</td>
              <td>{playoffGoalieTotal.penaltyMinutes}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </>
  )}
</section>
