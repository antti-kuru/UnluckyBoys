---
import PlayerCard from "@components/PlayerCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { serverApi } from "@lib/api";
import type { Player } from "@lib/types";

let players: Player[] = [];
let error = "";

try {
  const response = await serverApi<{ items: Player[] }>("/hall-of-fame");
  players = response.items;
} catch (caught) {
  error = caught instanceof Error ? caught.message : "Could not load Hall of Fame.";
}
---

<SiteLayout title="Hall of Fame | Unlucky Boys" bodyClass="content-tight-page">
  <section class="page-head">
    <h1>Hall of Fame</h1>
  </section>
  {error && <section class="notice error">{error}</section>}
  <div class="roster-grid">
    {players.map((player) => <PlayerCard player={player} />)}
  </div>
</SiteLayout>
