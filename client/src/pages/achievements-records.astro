---
import RecordsPanel from "@components/RecordsPanel.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { serverApi } from "@lib/api";
import { seasonFinishes } from "@lib/history";

type Records = Record<string, Record<string, string | number | null>>;

let records: Records = {};
let error = "";

try {
  records = await serverApi<Records>("/records");
} catch (caught) {
  error = caught instanceof Error ? caught.message : "Could not load achievements and records.";
}
---

<SiteLayout title="Achievements & Records | Unlucky Boys" bodyClass="content-tight-page">
  <section class="page-head">
    <h1>Achievements & Records</h1>
  </section>
  {error && <section class="notice error">{error}</section>}
  <section class="wide-card season-finishes">
    <h2>ECL placements history</h2>
    <div class="table-wrap">
      <table class="placements-table">
        <thead>
          <tr>
            <th>Season</th>
            <th>Regular Season Finish</th>
            <th>Playoff Result</th>
          </tr>
        </thead>
        <tbody>
          {seasonFinishes.map((finish) => (
            <tr>
              <td>{finish.season}</td>
              <td>{finish.regularSeasonFinish}</td>
              <td>{finish.playoffResult}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
  <RecordsPanel records={records} />
</SiteLayout>
