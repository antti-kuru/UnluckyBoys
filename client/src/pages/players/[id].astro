---
export const prerender = false;

import PlayerProfile from "@components/PlayerProfile.astro";
import StatsTables from "@components/StatsTables.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { serverApi } from "@lib/api";
import type { GoalieStat, Player, PlayerStatsResponse, SkaterStat } from "@lib/types";

const id = Astro.params.id ?? "";
let player: Player | null = null;
let skaterStats: SkaterStat[] = [];
let skaterPlayoffStats: SkaterStat[] = [];
let goalieStats: GoalieStat[] = [];
let goaliePlayoffStats: GoalieStat[] = [];
let error = "";

try {
  const [playerResponse, statsResponse] = await Promise.all([
    serverApi<Player>(`/players/${id}`),
    serverApi<PlayerStatsResponse>(`/players/${id}/stats`)
  ]);
  player = playerResponse;
  skaterStats = statsResponse.skater;
  skaterPlayoffStats = statsResponse.skaterPlayoffs ?? [];
  goalieStats = statsResponse.goalie;
  goaliePlayoffStats = statsResponse.goaliePlayoffs ?? [];
} catch (caught) {
  error = caught instanceof Error ? caught.message : "Could not load player.";
}
---

<SiteLayout title={player ? `${player.name} | Unlucky Boys` : "Player | Unlucky Boys"} bodyClass="content-tight-page">
  {error && <section class="notice error">{error}</section>}
  {player && (
    <>
      <PlayerProfile player={player} />
      <StatsTables
        skaterStats={skaterStats}
        skaterPlayoffStats={skaterPlayoffStats}
        goalieStats={goalieStats}
        goaliePlayoffStats={goaliePlayoffStats}
      />
    </>
  )}
</SiteLayout>
