---
import SiteLayout from "@layouts/SiteLayout.astro";
import { historyParagraphs } from "@lib/history";
---

<SiteLayout
  title="About us | Unlucky Boys"
  description="About the Unlucky Boys NHL Esports organization"
  bodyClass="article-tight-page"
>
  <section class="page-head article-page-head">
    <h1>About us</h1>
  </section>
  <article class="article-page">
    <div class="article-body">
      {historyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</SiteLayout>
