---
import LeagueStandings from "@components/LeagueStandings.astro";
import NewsCard from "@components/NewsCard.astro";
import UpcomingGames from "@components/UpcomingGames.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { serverApi } from "@lib/api";
import type { LeagueStandings as LeagueStandingsType, News, TeamSchedule } from "@lib/types";

let homeNews: News[] = [];
let standings: LeagueStandingsType | null = null;
let upcomingSchedule: TeamSchedule | null = null;
let playedSchedule: TeamSchedule | null = null;
let error = "";
let standingsError = "";
let scheduleError = "";

try {
  const newsResponse = await serverApi<{ items: News[] }>("/news?limit=3&offset=0");
  homeNews = newsResponse.items;
} catch (caught) {
  error =
    caught instanceof Error
      ? caught.message
      : "Could not load home page content.";
}

try {
  standings = await serverApi<LeagueStandingsType>("/league-standings/250");
} catch (caught) {
  standingsError =
    caught instanceof Error
      ? caught.message
      : "Could not load league table.";
}

try {
  const [upcomingResponse, playedResponse] = await Promise.all([
    serverApi<TeamSchedule>("/team-schedule/250/159?status=unplayed"),
    serverApi<TeamSchedule>("/team-schedule/250/159?status=played"),
  ]);
  upcomingSchedule = {
    ...upcomingResponse,
    games: upcomingResponse.games.slice(0, 6),
  };
  playedSchedule = {
    ...playedResponse,
    games: [...playedResponse.games].reverse().slice(0, 6),
  };
} catch (caught) {
  scheduleError =
    caught instanceof Error
      ? caught.message
      : "Could not load schedule.";
}
---

<SiteLayout bodyClass="home-page">
  {error && <section class="notice error">{error}</section>}
  <section class="home-hero-banner" aria-label="Unlucky Boys banner">
    <img src="/brand/banner.png" alt="Unlucky Boys team banner" />
  </section>
  <div class="home-content">
    <section class="home-grid">
      <div class="home-main">
        <div class="section-title">
          <h2>Latest News</h2>
        </div>
        <div class="cards">
          {homeNews.map((article) => <NewsCard article={article} />)}
        </div>
        <LeagueStandings standings={standings} error={standingsError} />
      </div>
      <aside class="home-sidebar">
        <UpcomingGames
          title="Upcoming Games"
          games={upcomingSchedule?.games ?? []}
          emptyText={scheduleError || "No upcoming games found."}
        />
        <UpcomingGames
          title="Recent Results"
          games={playedSchedule?.games ?? []}
          emptyText={scheduleError || "No recent results found."}
        />
        <div class="panel x-panel">
          <div class="x-feed" data-x-feed>
            <div class="third-party-consent" data-x-consent>
              <strong>X Feed</strong>
              <p>
                Loading the feed connects to X/SociableKit and may allow third-party cookies or storage.
              </p>
              <button class="command" type="button" data-x-consent-button>
                Load X feed
              </button>
            </div>
            <iframe
              data-src="https://widgets.sociablekit.com/twitter-feed/iframe/25691535"
              width="100%"
              height="1000"
              loading="lazy"
              title="UnluckyBoysNHL X feed"
              hidden></iframe>
          </div>
        </div>
      </aside>
    </section>
  </div>
  <script is:inline>
    const xFeedConsentKey = "ub_x_feed_consent";
    const xFeedFrame = document.querySelector("[data-x-feed] iframe");
    const xFeedConsent = document.querySelector("[data-x-consent]");
    const xFeedButton = document.querySelector("[data-x-consent-button]");

    const loadXFeed = () => {
      if (!(xFeedFrame instanceof HTMLIFrameElement)) return;
      xFeedFrame.src = xFeedFrame.dataset.src || "";
      xFeedFrame.hidden = false;
      if (xFeedConsent instanceof HTMLElement) xFeedConsent.hidden = true;
    };

    if (localStorage.getItem(xFeedConsentKey) === "accepted") loadXFeed();

    xFeedButton?.addEventListener("click", () => {
      localStorage.setItem(xFeedConsentKey, "accepted");
      loadXFeed();
    });
  </script>
</SiteLayout>
