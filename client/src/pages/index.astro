---
import LeagueStandings from "@components/LeagueStandings.astro";
import NewsCard from "@components/NewsCard.astro";
import UpcomingGames from "@components/UpcomingGames.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { serverApi } from "@lib/api";
import type { LeagueStandings as LeagueStandingsType, News, TeamSchedule } from "@lib/types";

let homeNews: News[] = [];
let standings: LeagueStandingsType | null = null;
let upcomingSchedule: TeamSchedule | null = null;
let playedSchedule: TeamSchedule | null = null;
let error = "";
let standingsError = "";
let scheduleError = "";

try {
  const newsResponse = await serverApi<{ items: News[] }>("/news?limit=3&offset=0");
  homeNews = newsResponse.items;
} catch (caught) {
  error =
    caught instanceof Error
      ? caught.message
      : "Could not load home page content.";
}

try {
  standings = await serverApi<LeagueStandingsType>("/league-standings/250");
} catch (caught) {
  standingsError =
    caught instanceof Error
      ? caught.message
      : "Could not load league table.";
}

try {
  const [upcomingResponse, playedResponse] = await Promise.all([
    serverApi<TeamSchedule>("/team-schedule/250/159?status=unplayed"),
    serverApi<TeamSchedule>("/team-schedule/250/159?status=played"),
  ]);
  upcomingSchedule = {
    ...upcomingResponse,
    games: upcomingResponse.games.slice(0, 6),
  };
  playedSchedule = {
    ...playedResponse,
    games: [...playedResponse.games].reverse().slice(0, 6),
  };
} catch (caught) {
  scheduleError =
    caught instanceof Error
      ? caught.message
      : "Could not load schedule.";
}
---

<SiteLayout bodyClass="home-page">
  {error && <section class="notice error">{error}</section>}
  <section class="home-hero-banner" aria-label="Unlucky Boys banner">
    <img src="/brand/banner.png" alt="Unlucky Boys team banner" />
  </section>
  <div class="home-content">
    <section class="home-grid">
      <div class="home-main">
        <div class="section-title">
          <h2>Latest News</h2>
        </div>
        <div class="cards">
          {homeNews.map((article) => <NewsCard article={article} />)}
        </div>
        <LeagueStandings standings={standings} error={standingsError} />
      </div>
      <aside class="home-sidebar">
        <UpcomingGames
          title="Upcoming Games"
          games={upcomingSchedule?.games ?? []}
          emptyText={scheduleError || "No upcoming games found."}
        />
        <UpcomingGames
          title="Recent Results"
          games={playedSchedule?.games ?? []}
          emptyText={scheduleError || "No recent results found."}
        />
        <div class="panel x-panel">
          <div class="x-feed">
            <iframe
              src="https://widgets.sociablekit.com/twitter-feed/iframe/25691535"
              width="100%"
              height="1000"
              title="UnluckyBoysNHL X feed"></iframe>
          </div>
        </div>
      </aside>
    </section>
  </div>
</SiteLayout>
